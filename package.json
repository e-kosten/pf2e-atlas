{
  "name": "pathfinder-2e-foundry-mcp",
  "version": "0.1.0",
  "description": "MCP server for Pathfinder 2E Foundry data exports",
  "type": "module",
  "bin": {
    "pathfinder-2e-foundry-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "mcp": "node dist/index.js",
    "refresh-data": "./scripts/refresh-pf2e-data.sh",
    "refresh-embeddings": "tsx src/refresh-embeddings.ts",
    "refresh-index": "tsx src/refresh-index.ts",
    "refresh-external": "tsx src/refresh-external.ts",
    "tui": "node dist/tags/cli/editorial/derived-tag-migration-workbench.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "sqlite-vec": "^0.1.9",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.2"
  }
}
