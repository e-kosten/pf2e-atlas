{
  "name": "pathfinder-2e-foundry-mcp",
  "version": "0.1.0",
  "description": "MCP server for Pathfinder 2E Foundry data exports",
  "type": "module",
  "bin": {
    "pathfinder-2e-foundry-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "analyze-derived-tag-evidence": "tsx src/tags/cli/evaluation/analyze-derived-tag-evidence.ts",
    "cluster-derived-tag-candidates": "tsx src/tags/cli/discovery/cluster-derived-tag-candidates.ts",
    "create-derived-tag-migration-session": "tsx src/tags/cli/editorial/create-derived-tag-migration-session.ts",
    "dev": "tsx src/index.ts",
    "discover-derived-tag-candidates": "tsx src/tags/cli/discovery/discover-semantic-candidates.ts",
    "discover-ruleable-cohorts": "tsx src/tags/cli/discovery/discover-ruleable-cohorts.ts",
    "discover-untagged-cohorts": "tsx src/tags/cli/discovery/discover-untagged-cohorts.ts",
    "derived-tag-migration-workbench": "tsx src/tags/cli/editorial/derived-tag-migration-workbench.ts",
    "evaluate-derived-tags": "tsx src/tags/cli/evaluation/evaluate-gaps.ts",
    "evaluate-derived-tag-movement": "tsx src/tags/cli/evaluation/evaluate-movement.ts",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "import-derived-tag-migration": "tsx src/tags/cli/editorial/import-derived-tag-migration.ts",
    "lint": "eslint . --cache --cache-location .cache/eslint/",
    "lint:fix": "npm run lint -- --fix",
    "lint-derived-tag-migration-session": "tsx src/tags/cli/editorial/lint-derived-tag-migration-session.ts",
    "refresh-data": "./scripts/refresh-pf2e-data.sh",
    "refresh-embeddings": "tsx src/refresh-embeddings.ts",
    "refresh-index": "tsx src/refresh-index.ts",
    "refresh-external": "tsx src/refresh-external.ts",
    "review-derived-tag-migration": "tsx src/tags/cli/editorial/review-derived-tag-migration.ts",
    "start": "node dist/index.js",
    "summarize-derived-tag-review-queue": "tsx src/tags/cli/editorial/summarize-derived-tag-review-queue.ts",
    "preflight": "./scripts/preflight.sh",
    "typecheck:tests": "tsc -p tests/tsconfig.json",
    "verify": "npm run lint && npm run format && npm run build && npm run typecheck:tests && npm test",
    "install-hooks": "./scripts/install-git-hooks.sh",
    "test": "vitest run",
    "test:local-integration": "env PF2E_RUN_LOCAL_INTEGRATION_TESTS=1 vitest run tests/service/integration.local.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "sqlite-vec": "^0.1.9",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.2"
  }
}
