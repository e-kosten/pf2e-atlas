{
  "name": "pathfinder-2e-foundry-mcp",
  "version": "0.1.0",
  "description": "MCP server for Pathfinder 2E Foundry data exports",
  "type": "module",
  "bin": {
    "pathfinder-2e-foundry-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "analyze-derived-tag-evidence": "tsx src/tags/cli/analyze-derived-tag-evidence.ts",
    "cluster-derived-tag-candidates": "tsx src/tags/cli/cluster-derived-tag-candidates.ts",
    "create-derived-tag-migration-session": "tsx src/tags/cli/create-derived-tag-migration-session.ts",
    "dev": "tsx src/index.ts",
    "discover-derived-tag-candidates": "tsx src/tags/cli/discover-semantic-candidates.ts",
    "discover-ruleable-cohorts": "tsx src/tags/cli/discover-ruleable-cohorts.ts",
    "discover-untagged-cohorts": "tsx src/tags/cli/discover-untagged-cohorts.ts",
    "derived-tag-migration-workbench": "tsx src/tags/cli/derived-tag-migration-workbench.ts",
    "evaluate-derived-tags": "tsx src/tags/cli/evaluate-gaps.ts",
    "evaluate-derived-tag-movement": "tsx src/tags/cli/evaluate-movement.ts",
    "import-derived-tag-migration": "tsx src/tags/cli/import-derived-tag-migration.ts",
    "lint-derived-tag-migration-session": "tsx src/tags/cli/lint-derived-tag-migration-session.ts",
    "refresh-data": "./scripts/refresh-pf2e-data.sh",
    "refresh-embeddings": "tsx src/refresh-embeddings.ts",
    "refresh-index": "tsx src/refresh-index.ts",
    "refresh-external": "tsx src/refresh-external.ts",
    "review-derived-tag-migration": "tsx src/tags/cli/review-derived-tag-migration.ts",
    "start": "node dist/index.js",
    "summarize-derived-tag-review-queue": "tsx src/tags/cli/summarize-derived-tag-review-queue.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "sqlite-vec": "^0.1.9",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "ink-testing-library": "^4.0.0",
    "react-test-renderer": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
