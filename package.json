{
  "name": "pathfinder-2e-foundry-mcp",
  "version": "0.1.0",
  "description": "MCP server for Pathfinder 2E Foundry data exports",
  "type": "module",
  "bin": {
    "pathfinder-2e-foundry-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "discover-derived-tag-candidates": "tsx src/tags/discover-semantic-candidates.ts",
    "evaluate-derived-tags": "tsx src/tags/evaluate-gaps.ts",
    "evaluate-derived-tag-movement": "tsx src/tags/evaluate-movement.ts",
    "refresh-data": "./scripts/refresh-pf2e-data.sh",
    "refresh-embeddings": "tsx src/refresh-embeddings.ts",
    "refresh-index": "tsx src/refresh-index.ts",
    "refresh-external": "tsx src/refresh-external.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
