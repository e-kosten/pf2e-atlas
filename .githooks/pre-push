#!/bin/sh

set -eu

HOOK_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
. "$HOOK_DIR/../scripts/git-hooks/common.sh"

docs_only_push=1
saw_ref=0

while IFS=' ' read -r local_ref local_oid remote_ref remote_oid; do
  [ -n "${local_ref:-}" ] || continue
  saw_ref=1
  if ! push_range_is_docs_only "$local_oid" "$remote_oid"; then
    docs_only_push=0
    break
  fi
done

if [ "$saw_ref" -eq 0 ] || [ "$docs_only_push" -ne 1 ]; then
  echo "Running pre-push checks (build + test)..." >&2
  (
    cd scripts &&
      npm run build &&
      npm run test
  )
  exit 0
fi

echo "Docs-only push detected; skipping pre-push verification." >&2
